@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<urn:shapes:PersonShape> a sh:NodeShape ;
    sh:targetClass schema:Person ;

    sh:property [
        sh:path schema:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:name "name" ;
        sh:message "Name is required and must be a non-empty string." ;
    ] ;

    sh:property [
        sh:path schema:email ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 3 ;
        sh:name "email" ;
        sh:message "A valid email address is required." ;
    ] ;

    sh:property [
        sh:path schema:jobTitle ;
        sh:uniqueLang true ;
        sh:or ( [ sh:datatype xsd:string ] [ sh:datatype rdf:langString ] ) ;
        sh:name "jobTitle" ;
        sh:message "Job title must be a string, with at most one per language plus an optional untagged default." ;
    ] ;

    sh:property [
        sh:path schema:description ;
        sh:uniqueLang true ;
        sh:or ( [ sh:datatype xsd:string ] [ sh:datatype rdf:langString ] ) ;
        sh:name "description" ;
        sh:message "Bio must be a string, with at most one per language plus an optional untagged default." ;
    ] ;

    sh:property [
        sh:path schema:url ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "url" ;
        sh:message "Website URL must be a string." ;
    ] ;

    sh:property [
        sh:path schema:image ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "image" ;
        sh:message "Image URL must be a string." ;
    ] ;

    sh:property [
        sh:path schema:isActive ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:name "isActive" ;
        sh:message "Active status is required and must be a boolean." ;
    ] .
